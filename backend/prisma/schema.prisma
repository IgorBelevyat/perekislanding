// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Bundle Map ────────────────────────────────────────────
// Config: which bundles exist on the landing and which RetailCRM offers belong to them
model BundleMap {
  id             String   @id @default(uuid())
  slug           String   @unique // e.g. "basic", "optimal", "maximum"
  name           String   // Display name: "Мінімальний"
  baseOfferId    String   @map("base_offer_id") // RetailCRM main product offer ID
  addonOfferIds  Json     @default("[]") @map("addon_offer_ids") // jsonb: string[]
  rules          Json     @default("{}") // jsonb: qty rules, required/optional flags
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quotes Quote[]

  @@map("bundle_map")
}

// ─── Quote ─────────────────────────────────────────────────
// Server-side calculator result + price snapshot. Short-lived (30 min).
model Quote {
  id              String      @id @default(uuid())
  bundleId        String?     @map("bundle_id")
  bundle          BundleMap?  @relation(fields: [bundleId], references: [id])
  calcInput       Json        @map("calc_input") // { L, W, H } or { V }, k, etc.
  itemsSnapshot   Json        @map("items_snapshot") // [{offerId, name, qty, unitPrice, total}]
  totalsSnapshot  Json        @map("totals_snapshot") // {subtotal, discount?, total}
  pricingVersion  String      @map("pricing_version") // "retailcrm@<timestamp>" or hash
  expiresAt       DateTime    @map("expires_at")
  status          QuoteStatus @default(ACTIVE)
  createdAt       DateTime    @default(now()) @map("created_at")

  orders Order[]

  @@index([status, expiresAt])
  @@map("quote")
}

enum QuoteStatus {
  ACTIVE
  USED
  EXPIRED
}

// ─── Order ─────────────────────────────────────────────────
// Local order tracking + RetailCRM + payment status
model Order {
  id               String        @id @default(uuid())
  quoteId          String        @map("quote_id")
  quote            Quote         @relation(fields: [quoteId], references: [id])
  retailcrmOrderId String?       @map("retailcrm_order_id")
  customer         Json          // {name, phone, email?}
  delivery         Json          // {cityRef, warehouseRef, cityName, warehouseName}
  itemsSnapshot    Json          @map("items_snapshot")
  total            Decimal       @db.Decimal(10, 2)
  paymentMethod    PaymentMethod @map("payment_method")
  paymentStatus    PaymentStatus @default(PENDING) @map("payment_status")
  status           OrderStatus   @default(CREATED)
  idempotencyKey   String?       @unique @map("idempotency_key")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([retailcrmOrderId])
  @@index([paymentStatus])
  @@map("order")
}

enum PaymentMethod {
  ONLINE
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  COD
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  CONFIRMED
  CANCELLED
}

// ─── Integration Log ───────────────────────────────────────
// Audit trail for all external API calls (without secrets)
model IntegrationLog {
  id           String              @id @default(uuid())
  provider     IntegrationProvider
  action       String              // "quote_prices", "create_order", "np_warehouses", "callback"
  requestMeta  Json?               @map("request_meta") // without secrets
  responseMeta Json?               @map("response_meta")
  status       IntegrationStatus
  errorMessage String?             @map("error_message")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([provider, action, createdAt])
  @@map("integration_log")
}

enum IntegrationProvider {
  RETAILCRM
  NOVAPOSHTA
  LIQPAY
  GA4
}

enum IntegrationStatus {
  SUCCESS
  ERROR
}
