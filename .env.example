# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=perekis
POSTGRES_PASSWORD=perekis_secret
POSTGRES_DB=perekis_landing

# ── Backend ────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://perekis:perekis_secret@localhost:5432/perekis_landing
REDIS_URL=redis://localhost:6379

# ── RetailCRM ──────────────────────────────────────────────
RETAILCRM_URL=https://your-store.retailcrm.ru
RETAILCRM_API_KEY=your_api_key_here

# ── Nova Poshta ────────────────────────────────────────────
NP_API_KEY=your_np_api_key_here

# ── LiqPay ─────────────────────────────────────────────────
LIQPAY_PUBLIC_KEY=your_public_key
LIQPAY_PRIVATE_KEY=your_private_key

# ── GA4 ────────────────────────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret

# ── Frontend ───────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
