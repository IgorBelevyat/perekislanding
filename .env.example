# PostgreSQL 
POSTGRES_USER=perekis
POSTGRES_PASSWORD=perekis_secret
POSTGRES_DB=perekis_landing

# Server
NODE_ENV=development
DATABASE_URL=postgresql://perekis:perekis_secret@localhost:5432/perekis_landing
REDIS_URL=redis://localhost:6379

# RetailCRM 
RETAILCRM_URL=https://your-store.retailcrm.ua
RETAILCRM_API_KEY=your_api_key_here
CRM_SITE_CODE=landing-hlorka-ua
CRM_ORDER_METHOD=lending
SITE_URL=https://market.hlorka.ua

# Offer IDs (RetailCRM) 
OFFER_ID_PEROXIDE=101
OFFER_ID_TEST_STRIPS=
OFFER_ID_MEASURING_CUP=

# Price Types (RetailCRM → CRM codes) 
PRICE_TYPE_BASE=base
PRICE_TYPE_NASEZON=base
PRICE_TYPE_OPTIMAL=base
PRICE_TYPE_PRO=base

# CRM Payment Types 
CRM_PAYMENT_TYPE_ONLINE=liqpay
CRM_PAYMENT_TYPE_COD=cash-on-delivery
CRM_PAYMENT_TYPE_CASHLESS=bank-transfer

# CRM Delivery Types 
CRM_DELIVERY_TYPE_NP=novaposhta
CRM_DELIVERY_TYPE_COURIER=courier
CRM_DELIVERY_TYPE_PICKUP=pickup
