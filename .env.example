# Nova Poshta 
NP_API_KEY=your_np_api_key_here

# LiqPay 
LIQPAY_PUBLIC_KEY=your_public_key
LIQPAY_PRIVATE_KEY=your_private_key

# Google Tag Manager 
VITE_GTM_ID=GTM-XXXXXXX

# GA4 (legacy, не використовується) 
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# МійСклад
MOYSKLAD_TOKEN=your_moysklad_token
